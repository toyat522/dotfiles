# mod1 for alt, mod4 for super
set $mod Mod1

# Wallpaper
output * bg ~/.config/bg/planet.jpg fill

# Input: caps lock -> escape
input * {
    xkb_options caps:escape
}

input type:touchpad {
    natural_scroll enabled
    tap enabled
}

# Export Wayland env to dbus/systemd so applets and portals work
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

# Policykit agent (GUI password prompts for privilege escalation)
exec /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1

# XDG autostart
exec dex --autostart --environment sway

# Waybar
exec_always ~/.config/waybar/launch.sh

# Screen idle/lock
exec swayidle -w \
    timeout 300 'swaylock -f' \
    before-sleep 'swaylock -f'

# Night light
exec gammastep -P -O 5000

# Applets
exec nm-applet --indicator
exec blueman-applet

# Japanese input
exec $HOME/.config/sway/launch-im.sh

# Autotiling
exec_always $HOME/.local/bin/autotiling

# Volume
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Brightness
bindsym XF86MonBrightnessDown exec light -U 2
bindsym XF86MonBrightnessUp   exec light -A 2

# Toggle Japanese input
bindsym Mod4+space exec fcitx5-remote -t

# Screenshots
bindsym Print exec grim -g "$(slurp)" "$(xdg-user-dir PICTURES)/$(date +'%Y-%m-%d_%H-%M-%S').png"
bindsym ctrl+Print exec grim "$(xdg-user-dir PICTURES)/$(date +'%Y-%m-%d_%H-%M-%S').png"

# Floating modifier (Wayland: must specify 'normal')
floating_modifier $mod normal

# Drag tiling windows
tiling_drag modifier

# Start terminal
bindsym $mod+Shift+Return exec alacritty

# Kill focused window
bindsym $mod+Shift+c kill

# Launcher
bindsym $mod+p exec "rofi -modi drun,run -show drun -icon-theme 'Papirus' -show-icons"

# Change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Split
bindsym $mod+s split h
bindsym $mod+v split v

# Fullscreen
bindsym $mod+f fullscreen toggle

# Layout
bindsym $mod+t layout tabbed
bindsym $mod+e layout toggle split

# Toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# Change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# Workspaces
set $ws1  "1"
set $ws2  "2"
set $ws3  "3"
set $ws4  "4"
set $ws5  "5"
set $ws6  "6"
set $ws7  "7"
set $ws8  "8"
set $ws9  "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Lock screen
bindsym $mod+ctrl+x exec swaylock -f
# Reload config
bindsym $mod+ctrl+r reload
# Exit sway
bindsym $mod+ctrl+q exec swaynag -t warning -m 'Exit sway?' -B 'Yes, exit' 'swaymsg exit'

# Resize
bindsym $mod+ctrl+h resize shrink width  2 px
bindsym $mod+ctrl+j resize grow height   2 px
bindsym $mod+ctrl+k resize shrink height 2 px
bindsym $mod+ctrl+l resize grow width    2 px

# Color schemes
set $bgcolor    #e277f4
set $in-bgcolor #363636
set $text       #ffffff
set $u-bgcolor  #ff0000
set $indicator  #a8a3c1
set $in-text    #969696

#                       border          background      text       indicator   child_border
client.focused          $bgcolor        $bgcolor        $text      $indicator  $bgcolor
client.unfocused        $in-bgcolor     $in-bgcolor     $in-text   $in-bgcolor $in-bgcolor
client.focused_inactive $in-bgcolor     $in-bgcolor     $in-text   $in-bgcolor $in-bgcolor
client.urgent           $u-bgcolor      $u-bgcolor      $text      $u-bgcolor  $u-bgcolor

# Borders and gaps
default_border pixel 2
gaps inner 10
gaps outer 5
gaps bottom 2
gaps top 5
