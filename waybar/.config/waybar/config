{
    "layer": "top",
    "position": "top",
    "height": 26,
    "margin-top": 6,
    "margin-left": 16,
    "margin-right": 16,

    "modules-left": ["custom/launcher", "custom/sep", "sway/window"],
    "modules-center": ["sway/workspaces"],
    "modules-right": ["backlight", "pulseaudio", "network", "battery", "clock"],

    "custom/launcher": {
        "format": "<span size='14336'>Όε║</span>",
        "on-click": "rofi -modi drun,run -show drun -icon-theme 'Papirus' -show-icons",
        "tooltip": false
    },

    "custom/sep": {
        "format": "|",
        "tooltip": false
    },

    "sway/window": {
        "max-length": 53
    },

    "sway/workspaces": {
        "format": "<span size='14336'>{icon}</span>",
        "format-icons": {
            "1": "ΎΡψ ",
            "2": "≤░Ι╣ ",
            "3": "Όατ ",
            "4": "≤░αΡ ",
            "5": "≤░γσ ",
            "6": "ΎΤΚ ",
            "7": "≤░Λ┤ ",
            "8": "≤░Ιβ ",
            "9": "≤░ΩΔ ",
            "default": "ΎΚυ "
        }
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}",
        "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"]
    },

    "pulseaudio": {
        "format": "{icon} {volume}",
        "format-muted": "ΎΣο ",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },

    "network": {
        "interface": "wlp0s20f3",
        "format-wifi": "≤░νρ ",
        "format-disconnected": "≤░νφ ",
        "format-linked": "≤░νρ ",
        "interval": 3
    },

    "battery": {
        "bat": "BAT0",
        "adapter": "AC",
        "full-at": 98,
        "interval": 5,
        "format": "{icon} {capacity}",
        "format-charging": "≤░λε {capacity}",
        "format-full": "≤░Β╣ {capacity}",
        "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ"],
        "states": {
            "critical": 15
        }
    },

    "clock": {
        "interval": 5,
        "format": "ΎΕ│ {:%e %b %Y  ≤░ξΦ %I:%M %p}",
        "format-alt": "ΎΕ│ {:%a,%e  ≤░ξΦ %I:%M:%S %p}",
        "tooltip": false
    }
}
